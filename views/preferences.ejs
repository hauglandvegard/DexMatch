<%# Type and region preferences %>
<div class="w-full max-w-lg px-4">

    <h1 class="text-3xl font-pokemon text-[var(--color-pokemon-yellow)] mb-2 text-center">Preferences</h1>

    <div class="divider"></div>

    <form method="POST" action="/preferences">

        <div class="mb-6">
            <h2 class="text-sm font-pokemon text-base-content/70 mb-2 uppercase tracking-wide">Region</h2>
            <p class="text-xs text-base-content/50 mb-3">Show Pokémon from a specific region only.</p>
            <select name="region" class="select select-bordered w-full">
                <option value="0" <%= currentRegionId === null || currentRegionId === 0 ? 'selected' : '' %>>Any region</option>
                <% regions.forEach(function(region) { %>
                    <option value="<%= region.id %>" <%= currentRegionId === region.id ? 'selected' : '' %>>
                        <%= region.name.charAt(0).toUpperCase() + region.name.slice(1) %>
                    </option>
                <% }); %>
            </select>
        </div>

        <div class="divider"></div>

        <div class="mb-6">
            <h2 class="text-sm font-pokemon text-base-content/70 mb-2 uppercase tracking-wide">Types</h2>
            <p class="text-xs text-base-content/50 mb-3">Leave all unchecked to show every type.</p>
            <div class="grid grid-cols-3 gap-2">
                <% types.forEach(function(type) { %>
                    <label class="flex items-center gap-2 cursor-pointer p-2 rounded-lg border border-base-300 hover:border-[var(--color-pokemon-yellow)] transition-colors">
                        <input
                            type="checkbox"
                            name="types"
                            value="<%= type.id %>"
                            class="checkbox checkbox-warning checkbox-sm"
                            <%= wantedIds.has(type.id) ? 'checked' : '' %>
                        />
                        <span class="capitalize text-sm"><%= type.name %></span>
                    </label>
                <% }); %>
            </div>
        </div>

        <div class="flex gap-3 justify-center">
            <button type="submit" class="btn btn-warning font-pokemon">Save</button>
            <a href="/swipe" class="btn btn-ghost font-pokemon">Cancel</a>
        </div>
    </form>

</div>
