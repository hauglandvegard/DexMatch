<%# Core swiping interface — displays one Pokémon profile at a time %>
<div class="flex flex-col items-center w-full max-w-md">

    <div class="card bg-base-100 shadow-xl w-full">
        <figure class="px-10 pt-10">
            <img
                src="<%= profile.pokemon.isShiny ? profile.shinySpriteUrl : profile.spriteUrl %>"
                alt="<%= profile.speciesName %>"
                class="w-48 h-48 object-contain image-rendering-pixelated"
                style="image-rendering: pixelated;"
            />
        </figure>

        <div class="card-body">
            <div class="flex items-center gap-2">
                <h2 class="card-title text-2xl capitalize">
                    <%= profile.pokemon.name %> the <%= profile.speciesName %>
                </h2>
                <% if (profile.pokemon.isShiny) { %>
                    <span class="badge badge-warning">✨ Shiny</span>
                <% } %>
            </div>

            <div class="flex flex-wrap gap-1 mb-2">
                <span class="badge badge-outline">Lv. <%= profile.pokemon.level %></span>
                <span class="badge badge-outline">
                    <%= profile.pokemon.size.height / 10 %>m /
                    <%= profile.pokemon.size.weight / 10 %>kg
                </span>
            </div>

            <p class="text-base-content/70 text-sm italic">"<%= profile.pokemon.description %>"</p>

            <div class="divider"></div>

            <div class="grid grid-cols-3 gap-1 text-xs text-center mb-2">
                <div class="stat p-1">
                    <div class="stat-title text-xs">HP IV</div>
                    <div class="stat-value text-sm"><%= profile.pokemon.statsIV.hp %></div>
                </div>
                <div class="stat p-1">
                    <div class="stat-title text-xs">ATK IV</div>
                    <div class="stat-value text-sm"><%= profile.pokemon.statsIV.atk %></div>
                </div>
                <div class="stat p-1">
                    <div class="stat-title text-xs">DEF IV</div>
                    <div class="stat-value text-sm"><%= profile.pokemon.statsIV.def %></div>
                </div>
                <div class="stat p-1">
                    <div class="stat-title text-xs">SP.ATK</div>
                    <div class="stat-value text-sm"><%= profile.pokemon.statsIV.spAtk %></div>
                </div>
                <div class="stat p-1">
                    <div class="stat-title text-xs">SP.DEF</div>
                    <div class="stat-value text-sm"><%= profile.pokemon.statsIV.spDef %></div>
                </div>
                <div class="stat p-1">
                    <div class="stat-title text-xs">SPD</div>
                    <div class="stat-value text-sm"><%= profile.pokemon.statsIV.speed %></div>
                </div>
            </div>

            <div class="card-actions justify-between mt-2">
                <form method="POST" action="/swipe">
                    <input type="hidden" name="pokemonId" value="<%= profile.pokemon.id %>" />
                    <input type="hidden" name="liked" value="false" />
                    <button class="btn btn-error btn-lg">✕ Pass</button>
                </form>
                <form method="POST" action="/swipe">
                    <input type="hidden" name="pokemonId" value="<%= profile.pokemon.id %>" />
                    <input type="hidden" name="liked" value="true" />
                    <button class="btn btn-success btn-lg">♥ Like</button>
                </form>
            </div>
        </div>
    </div>

    <form method="POST" action="/logout" class="mt-4">
        <button class="btn btn-ghost btn-sm text-base-content/40">Logout</button>
    </form>
</div>
