<%#
    This is the main layout containing the navigation bar and the basic HTML structure.
%>
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DexMatch</title>

    <link rel="icon" href="/icon_dexmatch_color.svg" type="image/svg+xml">
    <link href="https://cdn.jsdelivr.net/npm/daisyui@4.7.2/dist/full.min.css" rel="stylesheet" type="text/css" />

    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="stylesheet" href="/style.css">
</head>
<body class="bg-base-200 min-h-screen">
    <div class="navbar bg-base-100 shadow-xl mb-8 rounded-box w-11/12 mx-auto mt-4">
        <div class="flex-1">
            <a href="/" class="btn btn-ghost gap-2">
                <img src="/icon_dexmatch_negative_dark_mode.svg" alt="" class="h-7 w-7" />
                <span class="text-xs font-pokemon leading-tight text-left text-[var(--color-pokemon-yellow)] pb-1">Dex<br/>Match</span>
            </a>
        </div>
        <% if (locals.currentUser) { %>
        <div class="flex-none gap-3 items-center pr-2">
            <a href="/favorites" class="btn btn-ghost btn-sm text-xs font-pokemon">♥ Matches</a>
            <span class="text-xs font-pokemon text-base-content/70 capitalize">
                <%= currentUser.displayName || currentUser.username %>
            </span>
            <form method="POST" action="/logout">
                <button class="btn btn-ghost btn-sm text-xs font-pokemon">Logout</button>
            </form>
        </div>
        <% } %>
    </div>

    <main class="container mx-auto flex justify-center">
        <%- body %>
    </main>
</body>
</html>
